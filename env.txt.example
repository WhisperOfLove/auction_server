# =============================================================================
# Example env for auction_server (copy to env.txt on the VPS)
# On your PC: edit ../haraj.config.json, then run:
#   python ../scripts/sync_haraj_config.py
# That generates env.txt locally — do NOT commit env.txt to git.
# =============================================================================

# --- API (required) ---
APP_PORT=8080
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:8080
UPLOAD_DIR=uploads

# --- PostgreSQL (required for saving posts) ---
POSTGRES_USER=auction
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=auction
POSTGRES_DSN=postgres://auction:CHANGE_ME@localhost:5432/auction?sslmode=disable

# --- Post lifecycle ---
FEED_VISIBLE_HOURS=72
MY_AUCTIONS_DELETE_DAYS_AFTER_EXPIRY=0

# --- Optional tuning ---
TOP_BIDS_PUSH_INTERVAL_SECONDS=10
FEED_REFRESH_INTERVAL_SECONDS=0
BID_COOLDOWN_SECONDS=300
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092
ADMIN_API_KEY=change-me-before-production

# --- Deploy notes (not read by Go) ---
ARVAN_SERVER_IP=YOUR_SERVER_IP
ARVAN_SSH=ubuntu@YOUR_SERVER_IP
ARVAN_DOMAIN=your-admin-domain.example.com
